# ==========================================
# RestauFlow SaaS — Variables de Entorno
# Copiar como .env y configurar valores reales
# ==========================================

# Entorno
ENV=production
GIN_MODE=release
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=restauflow
DB_USER=postgres
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_PASSWORD_REDIS_AQUI

# CORS
CORS_ORIGIN=https://tudominio.com

# JWT (generar con: openssl rand -hex 32)
JWT_SECRET=GENERAR_SECRET_SEGURO_CON_OPENSSL
JWT_REFRESH_SECRET=GENERAR_OTRO_SECRET_SEGURO

# Cifrado AES-256-GCM (32 bytes hex)
# Generar con: openssl rand -hex 16
ENCRYPTION_KEY=GENERAR_KEY_32_CHARS_AQUI_12345

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXX

# WebSockets
ENABLE_WEBSOCKETS=true
