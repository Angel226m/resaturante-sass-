# Entorno
ENV=production
GIN_MODE=release
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=restauflow
DB_USER=postgres
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI
DB_SSL_MODE=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_PASSWORD_REDIS_AQUI

# CORS
